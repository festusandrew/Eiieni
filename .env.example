# Google Gemini API Key (Direct SDK client-side fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Integration Endpoint (Optional)
# If configured, all Gemini voice and scene requests are proxied via this backend gateway.
# Leave blank to fall back directly to Google GenAI Client SDK on the front end.
VITE_BACKEND_URL=http://localhost:5000
